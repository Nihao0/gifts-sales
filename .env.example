# Telegram API credentials
# Get from https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here
PHONE=+79001234567
SESSION_NAME=data/session

# Optional: Telegram 2FA password
# SESSION_PASSWORD=your_2fa_password

# Database
DB_URL=sqlite+aiosqlite:///data/gifts.db

# Behaviour
DRY_RUN=false
# Max FLOOD_WAIT seconds before scheduling retry instead of sleeping
FLOOD_SLEEP_THRESHOLD=60
MAX_JOB_ATTEMPTS=5
MAX_BULK_JOBS=50
# Optional hard cap for accidental overpriced listings
# MAX_PRICE_TON=100.0
# Default recipient for gifts send-to-portals
# PORTALS_RECIPIENT=@portals
# Read-only Portals market research connector.
# Copy the full Telegram Mini App Authorization header value, including "tma ".
# PORTALS_AUTH_DATA=tma ...
# PORTALS_API_BASE=https://portals-market.com/api
# Optional Telegram Bot API notifier for approval requests
# BOT_TOKEN=123456:bot_token
# APPROVAL_CHAT_ID=123456789

# Pricing: override TON→Stars rate (leave empty to fetch live from API)
# TON_TO_STARS_RATE=100.0
# Require explicit TON_TO_STARS_RATE before real listing operations
REQUIRE_TON_RATE_FOR_SALES=true

# Logging
LOG_LEVEL=INFO
# LOG_FORMAT=console   # "json" (default) | "console"
LOG_FORMAT=console
